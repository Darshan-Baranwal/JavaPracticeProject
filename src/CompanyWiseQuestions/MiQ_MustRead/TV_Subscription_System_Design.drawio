          </mxGeometry>
        </mxCell>
        <mxCell id="um-cUDg6QKTtpvbpUroB-126" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;QPS Estimation Template&lt;/span&gt;&lt;/h1&gt;&lt;p&gt;&amp;nbsp;• Assume 5M active users&lt;br/&gt;• 3 entitlement checks per day per user&lt;br/&gt;• Total daily checks = 15M&lt;br/&gt;• Average QPS ≈ 175&lt;br/&gt;• Peak QPS estimate = 2000–5000&lt;br/&gt;• Writes (subscriptions/purchases) typically &amp;lt;100 QPS&lt;br/&gt;• If &amp;lt;5k QPS → Modular Monolith&lt;br/&gt;• If &amp;gt;20k QPS → Separate Entitlement Service&lt;/p&gt;" vertex="1">
          <mxGeometry height="180" width="720" x="20" y="1890" as="geometry" />
        </mxCell>
        <mxCell id="um-cUDg6QKTtpvbpUroB-127" edge="1" parent="1" style="endArrow=none;dashed=1;html=1;rounded=0;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint y="2080" as="sourcePoint" />
            <mxPoint x="760" y="2080" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="um-cUDg6QKTtpvbpUroB-128" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;APIs Security&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="260" x="210" y="2090" as="geometry" />
        </mxCell>
        <mxCell id="um-cUDg6QKTtpvbpUroB-131" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;text-align: center;&quot;&gt;1. Client on login gets Client_secret from Auth Server.&lt;/span&gt;&lt;br style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;text-align: center;&quot;&gt;2. Client --&amp;gt; AuthServer for JWT Token with Client_credentials&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;text-align: center;&quot;&gt;3. Client --&amp;gt; API Gateway --&amp;gt; with JWT&lt;br&gt;4.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Gateway validates token signature/or with Auth Server&lt;br&gt;5.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;JWT contains:&lt;/span&gt;&lt;/p&gt;&lt;br/&gt;&lt;ul data-start=&quot;558&quot; data-end=&quot;599&quot;&gt;&lt;br/&gt;&lt;li data-start=&quot;558&quot; data-end=&quot;567&quot;&gt;&lt;br/&gt;&lt;p data-start=&quot;560&quot; data-end=&quot;567&quot;&gt;user_id&lt;/p&gt;&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-start=&quot;568&quot; data-end=&quot;575&quot;&gt;&lt;br/&gt;&lt;p data-start=&quot;570&quot; data-end=&quot;575&quot;&gt;roles&lt;/p&gt;&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-start=&quot;576&quot; data-end=&quot;590&quot;&gt;&lt;br/&gt;&lt;p data-start=&quot;578&quot; data-end=&quot;590&quot;&gt;token expiry&lt;/p&gt;&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-start=&quot;591&quot; data-end=&quot;599&quot;&gt;&lt;br/&gt;&lt;p data-start=&quot;593&quot; data-end=&quot;599&quot;&gt;issuer&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="120" width="630" x="40" y="2090" as="geometry" />
