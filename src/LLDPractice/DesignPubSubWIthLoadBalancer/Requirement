record Message(String tenant, String message) {
}
class Worker{
   public String status = "Free"; // Busy / Free


   public void consume(List<Message> messages, int i) {
       this.status = "Busy";
       messages.forEach(m -> {
           System.out.println("Consumer "+i+" is processing");
           System.out.println("Processing: "+m.message()+" from "+ m.tenant());
       });
       this.status = "Free";


   }
}
class Publisher{
   Queue<Message> messageQueue;
   Publisher(Queue<Message> messageQueue) {
       this.messageQueue = messageQueue;
   }


   void publish(List<Message> messages) {
       messages.forEach(m -> this.messageQueue.offer(m));
       System.out.println("Published the messages");
   }
}
// Worker{status: free/busy, consume:()->{}} -> List<Worker> the first free worker should get utilised


class Consumer {
   public Queue<Message> messageQueue;
   public DistributionDesign distributionDesignForWorker;
   public List<Worker> workers;
   Consumer(Queue<Message> messageQueue, DistributionDesign distributionDesignForWorker, List<Worker> workers) {
       this.messageQueue = messageQueue;
       this.distributionDesignForWorker = distributionDesignForWorker;
       this.workers = workers;
   }


   void consume(int i) {
       System.out.println("Consumer "+i+" is processing");
           if(!messageQueue.isEmpty()){
               Optional<Worker> freeWorker = this.distributionDesignForWorker.nextFreeWorker(this.workers);
               if(freeWorker.isPresent()){
                   Worker worker = freeWorker.get();
                   worker.consume(messageQueue.stream().toList(), i);
               }


           }
   }
}
